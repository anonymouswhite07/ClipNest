<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageData.title %></title>
    <meta name="description" content="<%= pageData.description %>">
    <meta name="keywords" content="video downloader, youtube downloader, instagram downloader, download youtube videos, save instagram reels, media extractor">
    <meta name="author" content="ClipNest Team">
    
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ENR97ZG9Y5"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ENR97ZG9Y5');
    </script>
    
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3252528898114371" crossorigin="anonymous"></script>
    
    <!-- Bing Webmaster Tools -->
    <meta name="msvalidate.01" content="EEA3B1A1AF847A096464F8A3EB3D182C" />
    
    <!-- Icons & PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#09090b">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-192.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
    
    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://clipnest.white0.me/">
    <meta property="og:title" content="<%= pageData.title %>">
    <meta property="og:description" content="<%= pageData.description %>">
    <meta property="og:image" content="https://clipnest.white0.me/og-image.jpg">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@ClipNest">
    <meta name="twitter:title" content="<%= pageData.title %>">
    <meta name="twitter:description" content="<%= pageData.description %>">
    <meta name="twitter:image" content="https://clipnest.white0.me/og-image.jpg">

    <link rel="canonical" href="https://clipnest.white0.me/">
    <link rel="stylesheet" href="/style.css?v=1.5">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'">
    
    <!-- Structured Data (SoftwareApplication & FAQ) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ClipNest",
      "operatingSystem": "All",
      "applicationCategory": "MultimediaApplication",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "ratingCount": "1250"
      }
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        <% pageData.faqs.forEach((faq, index) => { %>
        {
          "@type": "Question",
          "name": "<%= faq.q %>",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<%= faq.a %>"
          }
        }<%= index < pageData.faqs.length - 1 ? ',' : '' %>
        <% }) %>
      ]
    }
    </script>
</head>
<body>
    <div class="app-bg"></div>

    <main class="container">
        <nav class="navbar">
            <div class="logo">
                <a href="/" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.5rem;" aria-label="ClipNest Home">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    <span class="logo-text">ClipNest</span>
                </a>
            </div>
            <div class="nav-links">
                <a href="/youtube-downloader" title="Download YouTube Videos">YouTube</a>
                <a href="/instagram-downloader" title="Download Instagram Reels">Instagram</a>
                <a href="/facebook-downloader" title="Download Facebook Videos">Facebook</a>
            </div>
        </nav>

        <header class="hero">
            <h1 class="headline"><%- pageData.h1 %></h1>
            <p class="subtitle"><%= pageData.subtitle %></p>
            <div class="platform-support">
                <div class="platform-pill" aria-label="Support for YouTube"><i class="fa-brands fa-youtube" aria-hidden="true"></i> YouTube</div>
                <div class="platform-pill" aria-label="Support for Instagram"><i class="fa-brands fa-instagram" aria-hidden="true"></i> Instagram</div>
                <div class="platform-pill" aria-label="Support for Facebook"><i class="fa-brands fa-facebook" aria-hidden="true"></i> Facebook</div>
                <div class="platform-pill"><i class="fa-solid fa-plus" aria-hidden="true"></i> More</div>
            </div>
        </header>

        <section class="glass-card main-card">
            <div class="input-wrapper" id="dropZone">
                <i class="fa-solid fa-link input-icon" aria-hidden="true"></i>
                <input type="text" id="urlInput" placeholder="Paste <%= pageData.platform %> link here..." autocomplete="off" aria-label="Video URL Input">
                <button id="pasteBtn" class="btn-icon" title="Paste from Clipboard" aria-label="Paste from Clipboard">
                    <i class="fa-solid fa-paste" aria-hidden="true"></i>
                </button>
                <button id="fetchBtn" class="btn-primary" aria-label="Fetch Media Information">
                    <span>Fetch</span>
                    <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                </button>
            </div>
            
            <div id="loadingState" class="hidden">
                <div class="loader-wrapper">
                    <div class="loader"></div>
                    <p>Analyzing media source...</p>
                </div>
            </div>

            <div id="resultContainer" class="hidden">
                <div class="media-preview">
                    <div class="thumbnail-container">
                        <img id="thumbnail" src="" alt="Media Preview Thumbnail">
                        <div class="badge" id="platformBadge">YouTube</div>
                    </div>
                    <div class="media-info">
                        <h2 id="mediaTitle">Video Title Goes Here</h2>
                        <p id="mediaUploader" class="uploader">Uploader Name</p>
                        <div class="meta-tags" id="mediaDuration">
                            <span><i class="fa-regular fa-clock"></i> --:--</span>
                        </div>
                    </div>
                </div>

                <div class="options-container">
                    <h3>Select Format & Quality</h3>
                    <div class="format-grid" id="formatList">
                        <!-- Formats will be injected here -->
                    </div>
                </div>
            </div>

            <div id="errorState" class="hidden">
                <div class="error-content">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <p id="errorMessage">Something went wrong. Please try again.</p>
                    <button class="btn-secondary" onclick="resetApp()">Try Another Link</button>
                </div>
            </div>
        </section>

        <% if (pageData.guide) { %>
        <section class="how-it-works">
            <h2 class="section-title">How to Download <%= pageData.platform %> Videos</h2>
            <div class="steps-grid">
                <% pageData.guide.forEach(item => { %>
                <div class="step-card">
                    <div class="step-num"><%= item.step %></div>
                    <h3><%= item.title %></h3>
                    <p><%= item.text %></p>
                </div>
                <% }) %>
            </div>
        </section>
        <% } %>

        <section class="seo-content-section">
            <h2 class="section-title">Why use ClipNest?</h2>
            <div class="features-grid">
                <div class="feature-item">
                    <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                    <h4>Ultra Fast</h4>
                    <p>Our server-side engine processes your requests in under 2 seconds.</p>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-shield-heart" aria-hidden="true"></i>
                    <h4>100% Safe</h4>
                    <p>No malware, no sketchy popups. Just your media, delivered securely.</p>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
                    <h4>High Quality</h4>
                    <p>Download in 1080p, 4K, or 320kbps MP3 whenever available.</p>
                </div>
            </div>

            <h2 class="section-title">Frequently Asked Questions</h2>
            <div class="faq-grid">
                <% pageData.faqs.forEach(faq => { %>
                <div class="faq-card glass-card">
                    <h4><%= faq.q %></h4>
                    <p><%= faq.a %></p>
                </div>
                <% }) %>
            </div>
        </section>

        <footer class="main-footer">
            <div class="footer-grid">
                <div class="footer-info">
                    <div class="logo">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        <span>ClipNest</span>
                    </div>
                    <p>Fast, free, and secure media extraction tool for social media platforms.</p>
                </div>
                <div class="footer-links">
                    <div class="link-col">
                        <h5>Tools</h5>
                        <a href="/youtube-downloader">YouTube Downloader</a>
                        <a href="/youtube-to-mp3">YouTube to MP3</a>
                        <a href="/instagram-downloader">Instagram Downloader</a>
                        <a href="/facebook-downloader">Facebook Downloader</a>
                    </div>
                    <div class="link-col">
                        <h5>Legal</h5>
                        <a href="/privacy-policy">Privacy Policy</a>
                        <a href="/terms-of-service">Terms of Service</a>
                        <a href="/contact">Contact Us</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2023 ClipNest. Made for creators.</p>
            </div>
        </footer>
    </main>

    <!-- Ad Interstitial Modal -->
    <div id="adModal" class="hidden modal-overlay">
        <div class="modal-content glass-card">
            <h3>Preparing your download...</h3>
            <p class="modal-subtitle">Supporting ClipNest allows us to keep it free.</p>
            
            <div class="ad-container">
                <!-- AdSense Ad Unit -->
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-3252528898114371"
                     data-ad-slot="YOUR_AD_SLOT_ID"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
            </div>
            
            <div id="adCountdownWrapper" class="countdown-wrapper">
                <div class="loader-circle"></div>
                <p>Starting in <span id="adCountdown" class="countdown-number">5</span> seconds</p>
            </div>
        </div>
    </div>

    <!-- Cookie Consent Banner -->
    <div id="cookieBanner" class="hidden glass-card cookie-banner">
        <p>We use cookies (via Google Analytics & AdSense) to improve your experience and fund our free service. <a href="/privacy.html" style="color: var(--primary); text-decoration: none;">Learn more</a>.</p>
        <button id="acceptCookies" class="btn-primary" style="padding: 0.5rem 1rem; width: auto; font-size: 0.9rem;">
            <span>Got it</span>
        </button>
    </div>

    <div id="toastContainer"></div>

    <script src="/app.js?v=1.5"></script>
</body>
</html>
